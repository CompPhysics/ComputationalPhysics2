\PYG{n}{solutions}\PYG{p}{,} \PYG{n}{scores} \PYG{o}{=} \PYG{n}{gradient\PYGZus{}descent}\PYG{p}{(}\PYG{n}{objective}\PYG{p}{,} \PYG{n}{derivative}\PYG{p}{,} \PYG{n}{bounds}\PYG{p}{,} \PYG{n}{n\PYGZus{}iter}\PYG{p}{,} \PYG{n}{step\PYGZus{}size}\PYG{p}{,} \PYG{n}{momentum}\PYG{p}{)}
