\PYG{c+c1}{\PYGZsh{} gradient descent algorithm}
\PYG{k}{def}\PYG{+w}{ }\PYG{n+nf}{gradient\PYGZus{}descent}\PYG{p}{(}\PYG{n}{objective}\PYG{p}{,} \PYG{n}{derivative}\PYG{p}{,} \PYG{n}{bounds}\PYG{p}{,} \PYG{n}{n\PYGZus{}iter}\PYG{p}{,} \PYG{n}{step\PYGZus{}size}\PYG{p}{,} \PYG{n}{momentum}\PYG{p}{)}\PYG{p}{:}
